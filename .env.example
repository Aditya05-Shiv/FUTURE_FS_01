PORT=5050

# Comma-separated allowed browser origins for CORS (local dev + production).
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174

# Render sets RENDER_EXTERNAL_URL automatically (e.g. https://your-app.onrender.com).
# Add it here only for local testing against a deployed API.
# RENDER_EXTERNAL_URL=https://your-app.onrender.com

MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?appName=<app>

# Optional: enable email notifications for contact messages.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
